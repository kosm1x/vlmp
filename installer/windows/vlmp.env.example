# VLMP configuration file.
# Copy to %ProgramData%\vlmp\vlmp.env and uncomment what you need.
# That folder is locked to Administrators (on purpose) -- edit as Administrator.
# Only VLMP_* keys are read; real environment variables take precedence.
# Restart VLMP (console window or service) after editing.

# Note: the installer's firewall rule and shortcuts assume port 8080 --
# if you change it, update the firewall rule and use http://localhost:<port>.
#VLMP_PORT=8080
#VLMP_HOST=0.0.0.0
#VLMP_SERVER_NAME=VLMP
#VLMP_TMDB_API_KEY=
#VLMP_PUBLIC_URL=
#VLMP_CORS_ORIGIN=

# Transcoding
#VLMP_FFMPEG_PATH=
#VLMP_FFPROBE_PATH=
#VLMP_TRANSCODE_PRESET=veryfast
#VLMP_HW_TRANSCODE=off
#VLMP_MAX_TRANSCODE_SESSIONS=4
#VLMP_MIN_FREE_DISK_MB=2048

# Library + backups
#VLMP_EMPTY_TRASH_ON_SCAN=true
#VLMP_BACKUP_INTERVAL_HOURS=24
#VLMP_BACKUP_RETENTION=7

# Scanning
# Extracting embedded subtitles during a scan demuxes every file END TO END
# and pins the media drive at 100% for the whole scan -- leave this off unless
# you want to pre-warm subtitles overnight. Playback extracts on demand.
#VLMP_EXTRACT_SUBS_ON_SCAN=false
#VLMP_FFPROBE_TIMEOUT_MS=30000
