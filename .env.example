# VLMP Configuration
# Copy to .env and adjust values

# Server
VLMP_PORT=8080
VLMP_HOST=0.0.0.0

# Data directory (database, transcode cache)
VLMP_DATA_DIR=./data

# Security — CHANGE THIS in production
VLMP_JWT_SECRET=change-me-to-a-random-secret
VLMP_JWT_EXPIRES_IN=24h

# FFmpeg paths (if not in $PATH)
# VLMP_FFMPEG_PATH=/usr/bin/ffmpeg
# VLMP_FFPROBE_PATH=/usr/bin/ffprobe

# TMDb API key (optional, for metadata enrichment)
# VLMP_TMDB_API_KEY=your-api-key
