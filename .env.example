# VLMP configuration — every variable the server reads, with its default.
# Copy to .env and export in your shell / systemd unit / compose environment
# (VLMP does not auto-load a dotenv file from the repo; the Windows installer
# reads <dataDir>/vlmp.env — see installer/windows/vlmp.env.example).

# ── Core ────────────────────────────────────────────────────────────
#VLMP_PORT=8080
#VLMP_HOST=0.0.0.0
#VLMP_DATA_DIR=./data              # SQLite db, transcode cache, subtitles, thumbs, backups

# REQUIRED in production: the server refuses to boot with the dev default.
# Generate one:  openssl rand -hex 32
#VLMP_JWT_SECRET=
#VLMP_JWT_SECRET_FILE=             # alternative: path to a file holding the secret
#VLMP_JWT_EXPIRES_IN=24h

# ── Metadata ────────────────────────────────────────────────────────
#VLMP_TMDB_API_KEY=                # free key: https://www.themoviedb.org/settings/api

# ── Federation ──────────────────────────────────────────────────────
#VLMP_SERVER_NAME=VLMP
#VLMP_PUBLIC_URL=                  # public URL peers use to reach this server

# ── Transcoding ─────────────────────────────────────────────────────
#VLMP_FFMPEG_PATH=ffmpeg
#VLMP_FFPROBE_PATH=ffprobe
#VLMP_TRANSCODE_PRESET=veryfast    # x264 preset, ultrafast..veryslow
#VLMP_HW_TRANSCODE=off            # off|auto|nvenc|qsv|amf|videotoolbox — GPU encode+decode; probed at boot, falls back to x264
#VLMP_MAX_TRANSCODE_SESSIONS=4
#VLMP_MIN_FREE_DISK_MB=2048        # transcoding pauses below this free-disk floor

# ── Scanning ────────────────────────────────────────────────────────
#VLMP_EMPTY_TRASH_ON_SCAN=true     # prune DB rows for files deleted from disk
#VLMP_FFPROBE_TIMEOUT_MS=30000
# Extracting embedded subtitles during a scan demuxes every file END TO END
# and pins the media drive at 100% for the whole scan — leave off unless you
# want to pre-warm subtitles overnight. Playback extracts on demand.
#VLMP_EXTRACT_SUBS_ON_SCAN=false

# ── Backups ─────────────────────────────────────────────────────────
#VLMP_BACKUP_INTERVAL_HOURS=24
#VLMP_BACKUP_RETENTION=7
